# Copy this file to .env (local dev) or .env.production (VPS) and fill in real values.
# Never commit the real .env files - they're already in .gitignore.

# --- Database ---
# Local dev (docker-compose.yml): postgresql://clinic_user:clinic_pass@db:5432/clinic_db
# Production (docker-compose.prod.yml): same format, host is "db" (the container name
# on the internal Docker network), not a public address.
DATABASE_URL=postgresql://clinic_user:clinic_pass@db:5432/clinic_db

# Password for the "db" service in docker-compose.prod.yml (referenced as ${DB_PASSWORD})
DB_PASSWORD=replace-with-a-strong-password

# --- Cloudflare Tunnel (production only) ---
# Get this token from the Cloudflare Zero Trust dashboard: Networks > Tunnels > your tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# --- Cloudflare R2 (offsite backups, production only) ---
# Create an R2 bucket + API token in the Cloudflare dashboard: R2 > Manage API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=clinic-software-backups

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h

# --- WhatsApp Business API (appointment reminders) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- App ---
PORT=3000
NODE_ENV=development
